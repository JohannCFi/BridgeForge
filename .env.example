# ============================================================
# BridgeForge – Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file!
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0

# Ethereum (Sepolia testnet)
ETHEREUM_RPC_URL=https://rpc.sepolia.org
ETHEREUM_TOKEN_ADDRESS=       # testEURCV ERC-20 contract address
ETHEREUM_PRIVATE_KEY=         # Bridge operator private key

# Solana (Devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_TOKEN_ADDRESS=         # testEURCV SPL token mint address
SOLANA_PRIVATE_KEY=           # Bridge operator private key

# XRP Ledger (Testnet)
XRPL_RPC_URL=wss://s.altnet.rippletest.net:51233
XRPL_ISSUER_ADDRESS=         # testEURCV issuer account
XRPL_PRIVATE_KEY=            # Issuer seed

# Stellar (Testnet)
STELLAR_RPC_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_ADDRESS=      # testEURCV issuer account
STELLAR_PRIVATE_KEY=         # Issuer secret key

# Attestation
ATTESTATION_PRIVATE_KEY=     # Secret key for signing attestations
