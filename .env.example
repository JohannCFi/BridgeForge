# ============================================================
# BridgeForge – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0

# Ethereum (Sepolia testnet)
ETHEREUM_RPC_URL=https://rpc.sepolia.org
ETHEREUM_TOKEN_ADDRESS=       # testEURCV ERC-20 contract address
ETHEREUM_PRIVATE_KEY=         # Bridge operator private key

# Solana (Devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_TOKEN_ADDRESS=         # testEURCV SPL token mint address
SOLANA_PRIVATE_KEY=           # Bridge operator private key

# XRP Ledger (Testnet)
XRPL_RPC_URL=wss://s.altnet.rippletest.net:51233
XRPL_ISSUER_ADDRESS=         # testEURCV issuer account
XRPL_PRIVATE_KEY=            # Issuer seed

# Stellar (Testnet)
STELLAR_RPC_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_ADDRESS=      # EURCV issuer public key
STELLAR_PRIVATE_KEY=         # Issuer secret key

# USDCV Testnet Token Addresses
ETHEREUM_USDCV_TOKEN_ADDRESS=  # tUSDCV ERC-20 contract address
SOLANA_USDCV_TOKEN_ADDRESS=    # tUSDCV SPL token mint address
# XRPL_USDCV_ISSUER_ADDRESS=  # (defaults to XRPL_ISSUER_ADDRESS if same issuer)
# XRPL_USDCV_PRIVATE_KEY=     # (defaults to XRPL_PRIVATE_KEY if same issuer)
# STELLAR_USDCV_ISSUER_ADDRESS= # (defaults to STELLAR_ISSUER_ADDRESS if same issuer)
# STELLAR_USDCV_PRIVATE_KEY=  # (defaults to STELLAR_PRIVATE_KEY if same issuer)

# Attestation
ATTESTATION_PRIVATE_KEY=     # Secret key for ECDSA signing attestations

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bridgeforge

# Redis (for Bull queue)
REDIS_URL=redis://localhost:6379

# ============================================================
# Production SG Forge Tokens (EURCV / USDCV)
# Fill these in to enable real SG Forge tokens on the bridge.
# Tokens appear in the UI automatically once addresses are set.
# ============================================================

# EURCV Production
# ETHEREUM_EURCV_PROD_ADDRESS=0x...   # EURCV ERC-20 contract (Ethereum mainnet)
# SOLANA_EURCV_PROD_ADDRESS=...       # EURCV SPL token mint (Solana mainnet)
# XRPL_EURCV_PROD_ISSUER=r...         # EURCV issuer account (XRPL mainnet)
# XRPL_EURCV_PROD_KEY=s...            # EURCV issuer seed
# STELLAR_EURCV_PROD_ISSUER=G...      # EURCV issuer public key (Stellar mainnet)
# STELLAR_EURCV_PROD_KEY=S...         # EURCV issuer secret key

# USDCV Production
# ETHEREUM_USDCV_PROD_ADDRESS=0x...   # USDCV ERC-20 contract (Ethereum mainnet)
# SOLANA_USDCV_PROD_ADDRESS=...       # USDCV SPL token mint (Solana mainnet)
# XRPL_USDCV_PROD_ISSUER=r...         # USDCV issuer account (XRPL mainnet)
# XRPL_USDCV_PROD_KEY=s...            # USDCV issuer seed
# STELLAR_USDCV_PROD_ISSUER=G...      # USDCV issuer public key (Stellar mainnet)
# STELLAR_USDCV_PROD_KEY=S...         # USDCV issuer secret key

# Frontend (set in frontend/.env or as VITE_ prefixed vars)
# VITE_NETWORK_MODE=mainnet           # Switch UI to mainnet names (Ethereum, Solana, etc.)
# VITE_ETHEREUM_EURCV_ADDRESS=0x...   # Frontend needs token addresses too
# VITE_ETHEREUM_USDCV_ADDRESS=0x...
# VITE_SOLANA_EURCV_ADDRESS=...
# VITE_SOLANA_USDCV_ADDRESS=...
# VITE_XRPL_EURCV_ISSUER=r...
# VITE_XRPL_USDCV_ISSUER=r...
# VITE_STELLAR_EURCV_ISSUER=G...
# VITE_STELLAR_USDCV_ISSUER=G...
